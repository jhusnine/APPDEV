document.getElementById("btnsearchstudent").addEventListener("click", function(e){
	const lname1 = document.getElementById("lname").value;
	const fname1 = document.getElementById("fname").value;
	const mname1 = document.getElementById("mname").value;
	const sname1 = document.getElementById("sname").value;
	const gender1 = document.getElementById("gender").value;
	const bday1 = document.getElementById("bday").value;
	const status1 = document.getElementById("status").value;
    const data = {
		lname: lname1,
		fname: fname1,
		mname: mname1,
		sname: sname1,
		gender: gender1,
		bday: bday1,
		status: status1
	};
	fetch("search_students.php", {
		method: "POST",
		headers: {
			"Content-Type": "application/json"
		},
		body: JSON.stringify(data)
	})
	.then(response => response.json())
	.then(result => {
		if (result.lenght > 0)
		{
			document.getElementById("Message").innerHTML ="FAILED";
		} else {
			document.getElementById("Message").innerHTML ="SUCCESS";

		}
	});
});

