<?php
$host = "10.70.0.55";
$dbname = "students";
$user = "boot";
$password = "boot";

try {
    $pdo = new PDO("mysql:host=$host;dbname=$dbname;charset=utf8", $user, $password);
    $pdo->setAttribute(PDO::ATTR_ERRMODE, PDO::ERRMODE_EXCEPTION);
	$data = json_decode(file_get_contents("php://input"), true);
	$lname1 = $data['lname'];
	$fname1 = $data['fname'];
	$mname1 = $data['mname'];
	$sname1 = $data['sname'];
	$gender1 = $data['gender'];
	$bday1 = $data['bday'];
	$status1 = $data['status'];
	$sql = "INSERT INTO `basicinformation`( 
	`basicinfo_lname`,
	`basicinfo_fname`,
	`basicinfo_mname`,
	`basicinfo_sname`,
	`basicinfo_gender`,
	`basicinfo_bday`,
	`basicinfo_status`)
	VALUES(?,?,?,?,?,?,?);
	SELECT 'SUCCESS';";

	$stmt = $pdo->prepare($sql);
	$stmt->execute([$lname1,$fname1,$mname1,$sname1,$gender1,$bday1,$status1]);
	$student = $stmt->fetchAll(PDO::FETCH_ASSOC);
	echo json_encode($student);
} catch(PDOException $e) {
    die("Connection failed: " . $e->getMessage());
}
?>
